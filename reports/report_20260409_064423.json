      "recommended_value": "4096",
      "reason": "Increase concurrent connections per worker for better throughput",
      "impact": "high",
      "command": "sed -i 's/worker_connections.*/    worker_connections 4096;/' /etc/nginx/nginx.conf"
    },
    {
      "category": "nginx",
      "setting": "open_file_cache",
