  "bottlenecks": [
    {
      "issue": "Access logging enabled at high RPS",
      "current_state": "access_log /var/log/nginx/access.log main",
      "why_problem": "At 300K+ RPS, each request writes to disk causing severe I/O bottleneck and context switching overhead",
      "expected_impact": "Reduces throughput by 30-50% and increases latency significantly"
    },
    {
      "issue": "Worker file descriptor limit too low",
      "current_state": "worker_rlimit_nofile 1024",
      "why_problem": "Each worker can only open 1024 files, limiting concurrent connections and file caching",
      "expected_impact": "Limits concurrent connections and causes file descriptor exhaustion"
    },
    {
      "issue": "Worker connections severely limited",
      "current_state": "worker_connections 1024",
      "why_problem": "With 112 cores, total concurrent connections limited to ~115K instead of potential 450K+",
      "expected_impact": "Connection rejection under load, reduced throughput"
    },
    {
      "issue": "File caching disabled",
      "current_state": "open_file_cache off",
      "why_problem": "Every file access requires disk I/O instead of memory cache, especially bad for small/medium files",
      "expected_impact": "Significantly slower file serving, increased disk I/O"
    },
    {
      "issue": "Network receive/send buffers too small",
      "current_state": "rmem_max=212992, wmem_max=212992",
      "why_problem": "208KB buffers insufficient for 100Gbps interfaces, causes packet loss and retransmissions",
      "expected_impact": "Network throughput bottleneck, especially for larger files"
    },
    {
      "issue": "Async I/O disabled",
      "current_state": "aio off",
      "why_problem": "Synchronous I/O blocks worker threads, reducing concurrency for medium/large files",
      "expected_impact": "Poor performance on medium/large files, worker thread blocking"
    },
    {
      "issue": "Keep-alive requests limit too low",
      "current_state": "keepalive_requests 100",
      "why_problem": "Connections closed too frequently, causing connection setup overhead",
      "expected_impact": "Increased latency and CPU overhead from connection establishment"
    }
  ],
  "recommendations": [
    {
      "category": "nginx",
      "setting": "access_log",
      "current_value": "access_log /var/log/nginx/access.log main",
      "recommended_value": "access_log off",
      "reason": "Eliminates massive I/O overhead at high RPS",
      "impact": "high",
      "command": "sed -i 's/access_log.*/access_log off;/' /etc/nginx/nginx.conf"
    },
    {
      "category": "nginx",
      "setting": "worker_rlimit_nofile",
      "current_value": "1024",
      "recommended_value": "65535",
      "reason": "Allow workers to open many files for connections and caching",
      "impact": "high",
      "command": "sed -i 's/worker_rlimit_nofile.*/worker_rlimit_nofile 65535;/' /etc/nginx/nginx.conf"
    },
    {
      "category": "nginx",
      "setting": "worker_connections",
